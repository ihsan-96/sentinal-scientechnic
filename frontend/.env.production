# Backend URL baked into PRODUCTION builds (e.g. Netlify runs `vite build`, which is production
# mode and loads this file) — so deployed sites need NO dashboard env var.
# Local dev (`npm run dev` / `pnpm dev`) is development mode and ignores this, using the
# localhost default in src/config.ts. So an evaluator needs zero setup for the local backend.
VITE_API_URL=https://scientechnic.madian.in/api
